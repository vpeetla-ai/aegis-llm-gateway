GATEWAY_MODE=stub
# stub | byok — byok uses keys below when present
# demo = fail-open (portfolio); strict = fail-closed (budget/FinOps/cache deps)
CONTROL_PLANE_MODE=demo
SEMANTIC_CACHE_URL=http://127.0.0.1:8101
AGENTFINOPS_URL=http://127.0.0.1:8000
AGENTFINOPS_API_KEY=
GATEWAY_API_KEY=
DEFAULT_TENANT_ID=demo

# BYOK / free-tier (set GATEWAY_MODE=byok)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
VLLM_BASE_URL=

# Tenant identity (ADR-026/029)
# Comma allowlist; empty = org known consumer defaults
ALLOWED_TENANT_IDS=
# off | warn | enforce (warn + CONTROL_PLANE_MODE=strict => enforce)
TENANT_ENFORCEMENT=warn
REQUIRE_PRINCIPAL=false
